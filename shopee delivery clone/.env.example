# Copy to .env in this folder:
#   cp .env.example .env

# =============================================================================
# Database (required)
# =============================================================================

# Option A — Cloud Postgres (good for sharing with teammates)
# Neon:    https://neon.tech  → Connection string
# Supabase: https://supabase.com → Settings → Database → URI
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Option B — Local Docker Postgres (see README: pnpm db:up)
DATABASE_URL=postgresql://shopee:shopee@localhost:5432/shopee_delivery

# =============================================================================
# Servers
# =============================================================================

# API port (default 3001 — avoids clashing with other apps on 3000)
PORT=3001

# Optional: frontend dev port (default 5173)
# VITE_PORT=5173

# Optional: point the driver app at a remote API (LAN / deployed server)
# VITE_API_URL=http://192.168.1.10:3001

# Local dev: edit photos after delivery, gallery upload, change saved photos
# DEV_EDIT_PHOTOS=true
# VITE_DEV_EDIT_PHOTOS=true

# =============================================================================
# Damage detection model (optional — not required to run the app)
# =============================================================================
#
# Flow when enabled: driver uploads pickup/delivery photo → API calls your model
# → stores damageFlag (none | minor | severe) + shows message in the app.
#
# Implementation hook: artifacts/api-server/src/lib/damage-model.ts
#
# Option 1 — HTTP inference service (recommended to start)
#   Run your RipEye / CV model as a small POST endpoint, then set:
#
# DAMAGE_MODEL_ENABLED=true
# DAMAGE_MODEL_URL=http://localhost:8000/v1/analyze-package
# DAMAGE_MODEL_API_KEY=
# DAMAGE_MODEL_TIMEOUT_MS=30000
#
# Expected POST body:  { "image": "<base64>", "mimeType": "image/jpeg" }
# Expected response:   { "damageFlag": "none"|"minor"|"severe", "damageDetails": "...", "message": "..." }
#
# Option 2 — Keep disabled while developing UI / photos only
#
DAMAGE_MODEL_ENABLED=true
DAMAGE_MODEL_URL=http://localhost:8000/v1/analyze-package
DAMAGE_MODEL_API_KEY=
DAMAGE_MODEL_TIMEOUT_MS=30000
